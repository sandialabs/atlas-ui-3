# PR #554 fixture: Agent Portal feature flag ON, standard tier default,
# permissive tier NOT opted into. Assertions:
#   - /api/agent-portal/config reports enabled=true, default_tier=standard
#   - /api/agent-portal/admin/config reports allow_permissive_tier=false
#   - attempts to launch the permissive tier are rejected (403)
DEBUG_MODE=true
FEATURE_PROXY_SECRET_ENABLED=false
FEATURE_AGENT_PORTAL_ENABLED=true
AGENT_PORTAL_DEFAULT_SANDBOX_TIER=standard
AGENT_PORTAL_ALLOW_PERMISSIVE_TIER=false
AGENT_PORTAL_SANDBOX_BACKEND=bubblewrap
AGENT_PORTAL_AUDIT_SUBDIR=agent_portal/audit
