# PR #554 fixture: Agent Portal feature flag ON and admin has opted into
# the permissive tier (developer escape hatch). Assertions:
#   - /api/agent-portal/admin/config reports allow_permissive_tier=true
#   - a LaunchSpec with sandbox_tier=permissive passes validate_spec
DEBUG_MODE=true
FEATURE_PROXY_SECRET_ENABLED=false
FEATURE_AGENT_PORTAL_ENABLED=true
AGENT_PORTAL_DEFAULT_SANDBOX_TIER=standard
AGENT_PORTAL_ALLOW_PERMISSIVE_TIER=true
AGENT_PORTAL_SANDBOX_BACKEND=none
AGENT_PORTAL_AUDIT_SUBDIR=agent_portal/audit
